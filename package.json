{
  "name": "qfield4obm",
  "version": "1.0.0",
  "description": "QField plugin for OpenBioMaps",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "prepare": "husky",
    "test:js": "jest",
    "test:qml": "qmltestrunner -input tests/qml/ -import tests/qml/mocks",
    "test:all": "npm run test:js && npm run test:qml",
    "lint": "eslint . && qmllint main.qml"
  },
  "keywords": [
    "qfield",
    "openbiomaps",
    "qml",
    "biodiversity"
  ],
  "author": "Attila Ferenc",
  "license": "GPL-3.0",
  "devDependencies": {
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1"
  }
}
